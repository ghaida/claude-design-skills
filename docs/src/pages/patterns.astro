---
import Base from '../layouts/Base.astro';
import { loadPatterns, allPatterns, patternStats } from '../lib/patterns';

const categories = loadPatterns();
const patterns = allPatterns(categories);
const stats = patternStats(categories);
---

<Base title="Anti-Patterns — Intent" description={`${stats.total} named UX anti-patterns across ${stats.categories} categories. Deceptive design, dark patterns, and common UX failures — identified, categorized, and rated by severity.`}>
  <div class="page">
    <section class="patterns-hero" aria-labelledby="patterns-heading">
      <h1 id="patterns-heading">Anti-Patterns</h1>
      <p class="subtext muted">
        {stats.total} named patterns across {stats.categories} categories.
        Deceptive design, addictive mechanics, accessibility weaponization,
        and common UX failures. Each one identified, categorized, and rated.
      </p>
    </section>

    <!-- Catalog -->
    <h2 id="catalog-heading" class="visually-hidden">Pattern catalog</h2>
    <div class="patterns-layout">
      <!-- Filter Dropdown (mobile) -->
      <select class="filter-select" aria-label="Filter by category">
        <option value="all">All ({stats.total})</option>
        {categories.map((cat) => (
          <option value={cat.slug}>{cat.name} ({cat.patterns.length})</option>
        ))}
      </select>

      <!-- Filter Sidebar (desktop) -->
      <div class="filter-tabs" aria-label="Filter by category">
        <button
          class="filter-tab active"
          role="button"
          aria-pressed="true"
          data-category="all"
        >
          All ({stats.total})
        </button>
        {categories.map((cat) => (
          <button
            class="filter-tab"
            role="button"
            aria-pressed="false"
            data-category={cat.slug}
          >
            {cat.name} ({cat.patterns.length})
          </button>
        ))}
      </div>

      <!-- Pattern Table -->
      <div class="table-wrap">
        <table class="patterns-table">
          <thead>
            <tr>
              <th class="col-pattern">Pattern</th>
              <th class="col-severity">Severity</th>
              <th class="col-description">Description</th>
              <th class="hide-mobile col-category">Category</th>
            </tr>
          </thead>
          <tbody>
            {patterns.map((p) => (
              <tr data-category={p.categorySlug}>
                <td class="pattern-name">{p.name}</td>
                <td class="pattern-severity">
                  <span class={`severity severity--${p.severity.toLowerCase()}`}>
                    {p.severity}
                  </span>
                </td>
                <td class="pattern-desc">{p.description}</td>
                <td class="pattern-category hide-mobile">
                  <span class="pattern-cat mono small muted">{p.category}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Base>

<script is:inline src="/js/pattern-filter.js"></script>
